# Postgres
POSTGRES_USER=linkforge_owner
POSTGRES_PASSWORD=changeme_owner
POSTGRES_DB=linkforge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# App DB role (non-superuser, non-owner — used by the API/worker at runtime)
APP_DB_USER=linkforge_app
APP_DB_PASSWORD=changeme_app

# Authn DB role (used only by /auth/signup and /auth/login)
AUTHN_DB_USER=linkforge_authn
AUTHN_DB_PASSWORD=changeme_authn

# Full connection strings (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://linkforge_app:changeme_app@localhost:5432/linkforge
DATABASE_URL_AUTHN=postgresql+asyncpg://linkforge_authn:changeme_authn@localhost:5432/linkforge
DATABASE_URL_MIGRATIONS=postgresql+asyncpg://linkforge_owner:changeme_owner@localhost:5432/linkforge

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=dev-only-secret-change-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
